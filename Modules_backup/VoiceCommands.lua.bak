-- VoiceCommands.lua
-- Sistema de comandos de voz para Terror Squad AI

local VC = {}
VC.name = "VoiceCommands"

function VC:Initialize()
    self.commands = {
        ["atacar"] = self.CommandAttack,
        ["defender"] = self.CommandDefend,
        ["retirada"] = self.CommandRetreat,
        ["ayuda"] = self.CommandHelp,
        ["agrupar"] = self.CommandGroup,
        ["dispersar"] = self.CommandSpread,
        ["interrumpir"] = self.CommandInterrupt,
        ["foco"] = self.CommandFocus,
        ["estado"] = self.CommandStatus,
        ["cooldowns"] = self.CommandCooldowns
    }
    
    -- Registrar comando slash
    SLASH_TSVOZ1 = "/voz"
    SlashCmdList["TSVOZ"] = function(msg)
        VC:HandleCommand(msg)
    end
    
    DEFAULT_CHAT_FRAME:AddMessage("[TerrorSquadAI] Sistema de comandos de voz activado. Usa /voz [comando]", 1, 0.84, 0)
end

function VC:HandleCommand(msg)
    local cmd = string.lower(msg or "")
    
    if cmd == "" then
        self:ShowHelp()
        return
    end
    
    local handler = self.commands[cmd]
    if handler then
        handler(self)
    else
        DEFAULT_CHAT_FRAME:AddMessage("[TerrorSquadAI] Comando desconocido: " .. cmd, 1, 0, 0)
        self:ShowHelp()
    end
end

function VC:ShowHelp()
    DEFAULT_CHAT_FRAME:AddMessage("=== Comandos de Voz Disponibles ===", 1, 0.84, 0)
    DEFAULT_CHAT_FRAME:AddMessage("/voz atacar - Ordenar ataque concentrado", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz defender - Ordenar posicion defensiva", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz retirada - Ordenar retirada", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz ayuda - Solicitar ayuda", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz agrupar - Ordenar reagrupamiento", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz dispersar - Ordenar dispersion", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz interrumpir - Solicitar interrupcion", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz foco - Establecer fuego concentrado", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz estado - Mostrar estado del escuadron", 1, 1, 1)
    DEFAULT_CHAT_FRAME:AddMessage("/voz cooldowns - Mostrar cooldowns disponibles", 1, 1, 1)
end

function VC:CommandAttack()
    self:BroadcastCommand("ATACAR", "Concentren fuego en el objetivo!")
    if UnitExists("target") then
        local targetName = UnitName("target")
        SendChatMessage("[Terror Squad] ATACAR " .. targetName .. "!", "RAID")
    else
        DEFAULT_CHAT_FRAME:AddMessage("[TerrorSquadAI] Necesitas un objetivo", 1, 0, 0)
    end
end

function VC:CommandDefend()
    self:BroadcastCommand("DEFENDER", "Adopten posicion defensiva")
    SendChatMessage("[Terror Squad] DEFENDER! Posicion defensiva", "RAID")
end

function VC:CommandRetreat()
    self:BroadcastCommand("RETIRADA", "Retirada inmediata!")
    SendChatMessage("[Terror Squad] RETIRADA! Salgan ahora", "RAID")
end

